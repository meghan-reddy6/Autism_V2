datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-py"
  interface = "asyncio"
}

// ---------------------------------------------------------
// CORE MULTI-TENANT & RBAC
// ---------------------------------------------------------
model Tenant {
  id               String   @id @default(uuid())
  name             String
  npiNumber        String?  // National Provider Identifier
  address          String?
  contactEmail     String?
  subscriptionTier String   @default("ENTERPRISE")
  status           String   @default("ACTIVE") // ACTIVE, SUSPENDED, ARCHIVED
  maxUsers         Int      @default(500)
  maxStorageGB     Int      @default(100)
  maxAssessments   Int      @default(100000)
  featureFlags     Json?    // e.g., ["analytics", "audit_logs", "ai_reports"]
  createdAt        DateTime @default(now())
  
  deletedAt        DateTime?
  deletedBy        String?
  isDeleted        Boolean  @default(false)

  users        User[]
  patients     Patient[]
  appointments Appointment[]
  auditLogs    AuditLog[]
  assessmentSessions AssessmentSession[]
  assessmentTemplates AssessmentTemplate[]
}

enum Role {
  SUPER_ADMIN
  PLATFORM_ADMIN
  TENANT_ADMIN
  CLINICAL_ADMIN
  SUPERVISOR
  THERAPIST
  ASSESSOR
  DATA_ENTRY
  VIEWER
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String   @unique
  role         Role
  passwordHash String
  firstName    String     @default("Unknown")
  lastName     String     @default("Unknown")
  credentials  String?  // e.g., MD, PhD, MSW
  isActive     Boolean  @default(true)
  suspendedAt  DateTime?
  lastLoginAt  DateTime?
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  mfaEnabled          Boolean  @default(false)
  mfaSecret           String?
  passwordChangedAt   DateTime?
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  sessions     UserSession[]
  auditLogs    AuditLog[]
  appointments Appointment[] @relation("ProviderAppointments")
  clinicalNotes ClinicalNote[]
  createdSessions  AssessmentSession[] @relation("SessionCreator")
  reviewedSessions AssessmentSession[] @relation("SessionReviewer")
  approvedSessions AssessmentSession[] @relation("SessionApprover")
  approvedReports  Report[] @relation("ReportApprover")
}

model UserSession {
  id           String   @id @default(uuid())
  userId       String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  isRevoked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  user         User     @relation(fields: [userId], references: [id])
}

// ---------------------------------------------------------
// FULL EMR: PATIENT MODEL
// ---------------------------------------------------------
model Patient {
  id               String   @id @default(uuid())
  tenantId         String
  mrn              String   @unique // Medical Record Number
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           String
  
  // Demographics & Contact
  guardianName     String?
  guardianEmail    String?
  guardianPhone    String?
  emergencyContact String?
  address          String?
  insuranceInfo    Json?    // Provider, Group, Member ID
  referringPhysician String?

  // Clinical History
  birthHistory         String?
  developmentalHistory String?
  medicalHistory       String?
  allergies            Json?    // Array of allergies
  medications          Json?    // Current medications
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  deletedAt        DateTime?
  deletedBy        String?
  isDeleted        Boolean  @default(false)

  tenant           Tenant   @relation(fields: [tenantId], references: [id])
  assessments      Assessment[]
  appointments     Appointment[]
  clinicalNotes    ClinicalNote[]
  documents        Document[]
  treatmentPlans   TreatmentPlan[]
  consents         Consent[]
  assessmentSessions AssessmentSession[]
}

// ---------------------------------------------------------
// CLINICAL WORKFLOW
// ---------------------------------------------------------
model Appointment {
  id           String   @id @default(uuid())
  tenantId     String
  patientId    String
  providerId   String
  scheduledAt  DateTime
  durationMins Int      @default(60)
  status       String   @default("SCHEDULED") // COMPLETED, CANCELLED, NO_SHOW
  type         String   // INTAKE, FOLLOW_UP, THERAPY

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])
  provider     User     @relation("ProviderAppointments", fields: [providerId], references: [id])
}

model Assessment {
  id             String   @id @default(uuid())
  tenantId       String
  patientId      String
  
  scaleType      String   // CARS, GARS-2, M-CHAT-R
  itemScores     Json
  totalScore     Float
  
  // ML & Explainability Integration
  predictedRisk  String?
  confidence     Float?
  shapValues     Json?    // Feature importance breakdown
  trajectory     Json?    // 6-month prediction
  
  // Intake Context
  medicalHistory String?
  lifestyleInfo  String?
  symptoms       Json?
  
  status         String   @default("DRAFT") // FINALIZED
  createdAt      DateTime @default(now())
  
  deletedAt      DateTime?
  deletedBy      String?
  isDeleted      Boolean  @default(false)

  patient        Patient  @relation(fields: [patientId], references: [id])
}

model ClinicalNote {
  id           String   @id @default(uuid())
  patientId    String
  authorId     String
  
  // SOAP Format
  subjective   String?
  objective    String?
  assessment   String?
  plan         String?
  
  createdAt    DateTime @default(now())
  isSigned     Boolean  @default(false)

  patient      Patient  @relation(fields: [patientId], references: [id])
  author       User     @relation(fields: [authorId], references: [id])
}

model TreatmentPlan {
  id           String   @id @default(uuid())
  patientId    String
  goals        Json     // List of therapeutic goals
  interventions Json    // CDSS recommended interventions
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())

  patient      Patient  @relation(fields: [patientId], references: [id])
}

// ---------------------------------------------------------
// COMPLIANCE & SECURITY
// ---------------------------------------------------------
model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  action       String   // e.g., "VIEW_PATIENT", "EDIT_NOTE"
  resource     String   // "Patient", "Assessment"
  resourceId   String
  beforeState  Json?
  afterState   Json?
  changes      Json?
  timestamp    DateTime @default(now())
  ipAddress    String?

  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
}

model Consent {
  id           String   @id @default(uuid())
  patientId    String
  documentType String   // HIPAA, TREATMENT_CONSENT
  signedAt     DateTime @default(now())
  signatureUrl String?
  
  patient      Patient  @relation(fields: [patientId], references: [id])
}

model Document {
  id           String   @id @default(uuid())
  patientId    String
  fileType     String   // PDF, JPG
  s3Url        String   // Encrypted storage reference
  uploadedAt   DateTime @default(now())

  patient      Patient  @relation(fields: [patientId], references: [id])
}

// ---------------------------------------------------------
// ASSESSMENT & REPORTING SYSTEM
// ---------------------------------------------------------
model AssessmentSession {
  id                   String   @id @default(uuid())
  token                String   @unique @default(uuid())
  tenantId             String
  patientId            String
  assessmentTemplateId String
  status               String   @default("CREATED") // CREATED, SENT, IN_PROGRESS, SUBMITTED, UNDER_REVIEW, APPROVED, ARCHIVED, EXPIRED, CANCELLED
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  expiresAt            DateTime?
  submittedAt          DateTime?
  createdBy            String
  reviewedBy           String?
  approvedBy           String?
  
  deletedAt            DateTime?
  deletedBy            String?
  isDeleted            Boolean  @default(false)

  tenant               Tenant             @relation(fields: [tenantId], references: [id])
  patient              Patient            @relation(fields: [patientId], references: [id])
  template             AssessmentTemplate @relation(fields: [assessmentTemplateId], references: [id])
  creator              User               @relation("SessionCreator", fields: [createdBy], references: [id])
  reviewer             User?              @relation("SessionReviewer", fields: [reviewedBy], references: [id])
  approver             User?              @relation("SessionApprover", fields: [approvedBy], references: [id])
  responses            AssessmentResponse[]
  reports              Report[]
}

model AssessmentTemplate {
  id           String   @id @default(uuid())
  tenantId     String?  // Null means global template
  name         String
  description  String?
  type         String   // M-CHAT-R, CARS, INTAKE, etc.
  formSchema   Json     @map("schema")
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant       Tenant?  @relation(fields: [tenantId], references: [id])
  sessions     AssessmentSession[]
}

model AssessmentResponse {
  id                  String   @id @default(uuid())
  assessmentSessionId String
  fieldName           String
  value               Json     // Can be string, number, array, etc.
  metadata            Json?

  session             AssessmentSession @relation(fields: [assessmentSessionId], references: [id])
}

model Report {
  id                  String   @id @default(uuid())
  assessmentSessionId String
  status              String   @default("DRAFT") // DRAFT, AI_GENERATED, PENDING_REVIEW, APPROVED, ARCHIVED
  sections            Json?    // Optional JSON representation if structured, otherwise use ReportSection
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  approvedBy          String?
  approvedAt          DateTime?
  
  deletedAt           DateTime?
  deletedBy           String?
  isDeleted           Boolean  @default(false)

  session             AssessmentSession @relation(fields: [assessmentSessionId], references: [id])
  approver            User?             @relation("ReportApprover", fields: [approvedBy], references: [id])
  reportSections      ReportSection[]
}

model ReportSection {
  id       String @id @default(uuid())
  reportId String
  name     String
  content  String
  order    Int    @default(0)

  report   Report @relation(fields: [reportId], references: [id])
}
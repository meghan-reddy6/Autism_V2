# Database Configuration
# Explicit connection pooling constraints required for multi-tenant scalability
DATABASE_URL="postgresql://admin:your_secure_password_here@db:5432/clinical_db?connection_limit=100&pool_timeout=30"

# Redis queue configuration
REDIS_URL="redis://redis:6379/0"

# Async Job Processing
ARQ_MAX_JOBS=50

# Security (Replace with secure keys in production)
JWT_SECRET="generate_a_secure_random_string_for_production"
JWT_ALGORITHM="HS256"

# Microservices integration
ML_SERVICE_URL="http://ml-service:8001/analyze"

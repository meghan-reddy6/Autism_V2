datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-py"
  interface = "asyncio"
}

// ---------------------------------------------------------
// CORE MULTI-TENANT & RBAC
// ---------------------------------------------------------
model Organization {
  id               String   @id @default(uuid())
  name             String
  npiNumber        String?  // National Provider Identifier
  address          String?
  contactEmail     String?
  subscriptionPlan String   @default("ENTERPRISE")
  status           String   @default("ACTIVE") // ACTIVE, SUSPENDED, ARCHIVED
  maxUsers         Int      @default(500)
  maxStorageGB     Int      @default(100)
  maxAssessments   Int      @default(100000)
  featureFlags     Json?    // e.g., ["analytics", "audit_logs", "ai_reports"]
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  deletedAt        DateTime?
  deletedBy        String?
  isDeleted        Boolean  @default(false)

  users                User[]
  patients             Patient[]
  appointments         Appointment[]
  auditLogs            AuditLog[]
  assessmentSessions   AssessmentSession[]
  userSessions         UserSession[]
  reports              Report[]
  clinicalNotes        ClinicalNote[]
  treatmentPlans       TreatmentPlan[]
  consents             Consent[]
  documents            Document[]
  assessmentResponses  AssessmentResponse[]
  reportSections       ReportSection[]
  assessments          Assessment[]
}

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  DOCTOR
  RECEPTIONIST
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  email        String   @unique
  role         Role
  passwordHash String
  firstName    String     @default("Unknown")
  lastName     String     @default("Unknown")
  credentials  String?  // e.g., MD, PhD, MSW
  isActive     Boolean  @default(true)
  suspendedAt  DateTime?
  lastLoginAt  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  mfaEnabled          Boolean  @default(false)
  mfaSecret           String?
  passwordChangedAt   DateTime?
  failedLoginAttempts Int      @default(0)
  lockedUntil         DateTime?

  tenant       Organization @relation(fields: [tenantId], references: [id])
  sessions     UserSession[]
  auditLogs    AuditLog[]
  appointments Appointment[] @relation("ProviderAppointments")
  clinicalNotes ClinicalNote[]
  createdSessions  AssessmentSession[] @relation("SessionCreator")
  reviewedSessions AssessmentSession[] @relation("SessionReviewer")
  approvedSessions AssessmentSession[] @relation("SessionApprover")
  approvedReports  Report[] @relation("ReportApprover")
  assignedPatients Patient[] @relation("AssignedDoctor")
}

model UserSession {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  refreshToken String   @unique
  ipAddress    String?
  userAgent    String?
  isRevoked    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  expiresAt    DateTime
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  tenant       Organization @relation(fields: [tenantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
}

// ---------------------------------------------------------
// FULL EMR: PATIENT MODEL
// ---------------------------------------------------------
model Patient {
  id               String   @id @default(uuid())
  tenantId         String
  assignedDoctorId String?
  mrn              String   @unique // Medical Record Number
  firstName        String
  lastName         String
  dateOfBirth      DateTime
  gender           String
  
  // Demographics & Contact
  guardianName     String?
  guardianEmail    String?
  guardianPhone    String?
  emergencyContact String?
  address          String?
  insuranceInfo    Json?    // Provider, Group, Member ID
  referringPhysician String?

  // Clinical History
  birthHistory         String?
  developmentalHistory String?
  medicalHistory       String?
  allergies            Json?    // Array of allergies
  medications          Json?    // Current medications
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  
  deletedAt        DateTime?
  deletedBy        String?
  isDeleted        Boolean  @default(false)

  tenant           Organization @relation(fields: [tenantId], references: [id])
  assignedDoctor   User?    @relation("AssignedDoctor", fields: [assignedDoctorId], references: [id])
  
  assessments      Assessment[]
  appointments     Appointment[]
  clinicalNotes    ClinicalNote[]
  documents        Document[]
  treatmentPlans   TreatmentPlan[]
  consents         Consent[]
  assessmentSessions AssessmentSession[]
}

// ---------------------------------------------------------
// CLINICAL WORKFLOW
// ---------------------------------------------------------
model Appointment {
  id           String   @id @default(uuid())
  tenantId     String
  patientId    String
  providerId   String
  scheduledAt  DateTime
  durationMins Int      @default(60)
  status       String   @default("SCHEDULED") // COMPLETED, CANCELLED, NO_SHOW
  type         String   // INTAKE, FOLLOW_UP, THERAPY
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  tenant       Organization @relation(fields: [tenantId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])
  provider     User     @relation("ProviderAppointments", fields: [providerId], references: [id])
}

// Legacy Assessment Model
model Assessment {
  id             String   @id @default(uuid())
  tenantId       String
  patientId      String
  
  scaleType      String   // CARS, GARS-2, M-CHAT-R
  itemScores     Json
  totalScore     Float
  
  // ML & Explainability Integration
  predictedRisk  String?
  confidence     Float?
  shapValues     Json?    // Feature importance breakdown
  trajectory     Json?    // 6-month prediction
  
  // Intake Context
  medicalHistory String?
  lifestyleInfo  String?
  symptoms       Json?
  
  status         String   @default("DRAFT") // FINALIZED
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  
  deletedAt      DateTime?
  deletedBy      String?
  isDeleted      Boolean  @default(false)

  tenant         Organization @relation(fields: [tenantId], references: [id])
  patient        Patient  @relation(fields: [patientId], references: [id])
}

model ClinicalNote {
  id           String   @id @default(uuid())
  tenantId     String
  patientId    String
  authorId     String
  
  // SOAP Format
  subjective   String?
  objective    String?
  assessment   String?
  plan         String?
  
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  isSigned     Boolean  @default(false)
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  tenant       Organization @relation(fields: [tenantId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])
  author       User     @relation(fields: [authorId], references: [id])
}

model TreatmentPlan {
  id           String   @id @default(uuid())
  tenantId     String
  patientId    String
  goals        Json     // List of therapeutic goals
  interventions Json    // CDSS recommended interventions
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  tenant       Organization @relation(fields: [tenantId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])
}

// ---------------------------------------------------------
// COMPLIANCE & SECURITY
// ---------------------------------------------------------
model AuditLog {
  id           String   @id @default(uuid())
  tenantId     String
  userId       String
  action       String   // e.g., "VIEW_PATIENT", "EDIT_NOTE"
  resource     String   // "Patient", "Assessment"
  resourceId   String
  beforeState  Json?
  afterState   Json?
  changes      Json?
  timestamp    DateTime @default(now())
  ipAddress    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  tenant       Organization @relation(fields: [tenantId], references: [id])
  user         User     @relation(fields: [userId], references: [id])
}

model Consent {
  id           String   @id @default(uuid())
  tenantId     String
  patientId    String
  documentType String   // HIPAA, TREATMENT_CONSENT
  signedAt     DateTime @default(now())
  signatureUrl String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  tenant       Organization @relation(fields: [tenantId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])
}

model Document {
  id           String   @id @default(uuid())
  tenantId     String
  patientId    String
  fileType     String   // PDF, JPG
  s3Url        String   // Encrypted storage reference
  uploadedAt   DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  
  deletedAt    DateTime?
  deletedBy    String?
  isDeleted    Boolean  @default(false)

  tenant       Organization @relation(fields: [tenantId], references: [id])
  patient      Patient  @relation(fields: [patientId], references: [id])
}

// ---------------------------------------------------------
// ASSESSMENT & REPORTING SYSTEM
// ---------------------------------------------------------
enum ClinicianReviewStatus {
  PENDING
  APPROVED
  OVERRIDDEN
}

model AssessmentSession {
  id                   String   @id @default(uuid())
  token                String   @unique @default(uuid())
  tenantId             String
  patientId            String
  scaleType            String
  version              String   @default("1.0")
  status               String   @default("CREATED") // CREATED, SENT, IN_PROGRESS, SUBMITTED, UNDER_REVIEW, APPROVED, ARCHIVED, EXPIRED, CANCELLED, REJECTED
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  expiresAt            DateTime?
  submittedAt          DateTime?
  createdBy            String
  reviewedBy           String?
  approvedBy           String?
  
  clinicianReviewStatus ClinicianReviewStatus @default(PENDING)
  amendmentNotes       String?
  
  deletedAt            DateTime?
  deletedBy            String?
  isDeleted            Boolean  @default(false)

  tenant               Organization       @relation(fields: [tenantId], references: [id])
  patient              Patient            @relation(fields: [patientId], references: [id])
  creator              User               @relation("SessionCreator", fields: [createdBy], references: [id])
  reviewer             User?              @relation("SessionReviewer", fields: [reviewedBy], references: [id])
  approver             User?              @relation("SessionApprover", fields: [approvedBy], references: [id])
  responses            AssessmentResponse[]
  reports              Report[]
}



model AssessmentResponse {
  id                  String   @id @default(uuid())
  tenantId            String
  assessmentSessionId String
  fieldName           String
  value               Json     // Can be string, number, array, etc.
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  deletedAt           DateTime?
  deletedBy           String?
  isDeleted           Boolean  @default(false)

  tenant              Organization      @relation(fields: [tenantId], references: [id])
  session             AssessmentSession @relation(fields: [assessmentSessionId], references: [id])
}

model Report {
  id                  String   @id @default(uuid())
  tenantId            String
  assessmentSessionId String
  status              String   @default("DRAFT") // DRAFT, AI_GENERATED, PENDING_REVIEW, APPROVED, REJECTED, ARCHIVED
  sections            Json?    // Optional JSON representation if structured, otherwise use ReportSection
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  approvedBy          String?
  approvedAt          DateTime?
  
  deletedAt           DateTime?
  deletedBy           String?
  isDeleted           Boolean  @default(false)

  tenant              Organization      @relation(fields: [tenantId], references: [id])
  session             AssessmentSession @relation(fields: [assessmentSessionId], references: [id])
  approver            User?             @relation("ReportApprover", fields: [approvedBy], references: [id])
  reportSections      ReportSection[]
}

model ReportSection {
  id       String   @id @default(uuid())
  tenantId String
  reportId String
  name     String
  content  String
  order    Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  deletedAt DateTime?
  deletedBy String?
  isDeleted Boolean  @default(false)

  tenant   Organization @relation(fields: [tenantId], references: [id])
  report   Report       @relation(fields: [reportId], references: [id])
}